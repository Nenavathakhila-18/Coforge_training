<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:p="http://www.springframework.org/schema/p"
	xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">
       
       <bean id="address1" class="com.coforge.model.Address">
       <property name="city" value="city-1"></property>
        <property name="state" value="state-1"></property>
       </bean>

	<bean id="student1" class="com.coforge.model.Student">
		<property name="studentId" value="101"></property>
		<property name="studentName" value="Rahul Sharma"></property>
		<property name="address" ref="address1"></property>
		<property name="subjects">
			<list>
				<value>Java</value>
				<value>SpringCore</value>
				<value>Hibernate</value>
				<value>Mysql</value>
				<value>React</value>
			</list>
		</property>
		<property name="skills">
			<set>
				<value>communication</value>
				<value>problem solving</value>
				<value>Team work</value>
				<value>java</value>
			</set>
		</property>
		<property name="marks">
			<map>
				<entry key="java" value="95"/>
				<entry key="springcore" value="90"/>
				<entry key="hibernate" value="88"/>
				<entry key="Mysql" value="92"/>
				<entry key="react" value="85"/>
			</map>
		</property>		

	</bean>

</beans>